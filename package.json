{
  "name": "nba-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:py": "uv run ruff check scripts/ tests/python/",
    "lint:all": "npm run lint:py && npm run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:py": "uv run ruff format scripts/ tests/python/ && uv run ruff check --fix scripts/ tests/python/",
    "format:py:check": "uv run ruff format --check scripts/ tests/python/",
    "format:all": "npm run format && npm run format:py",
    "test": "jest --maxWorkers=50%",
    "test:js": "jest --runInBand",
    "test:py": "uv run pytest",
    "test:all": "concurrently \"npm run test:py\" \"npm run test\"",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@react-sigma/core": "^5.0.6",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sigma": "^3.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "lefthook": "^1.6.0",
    "prettier": "3.8.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  }
}
