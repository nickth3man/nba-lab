{
  "name": "nba-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:py": "uv run ruff check scripts/ tests/python/",
    "lint:all": "npm run lint:py && npm run lint",
    "test": "jest --maxWorkers=50%",
    "test:py": "uv run pytest --numprocesses=auto --dist=loadscope",
    "test:all": "concurrently \"npm run test:py\" \"npm run test\"",
    "format:py": "uv run ruff format scripts/ tests/python/ && uv run ruff check --fix scripts/ tests/python/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-sigma/core": "^5.0.6",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sigma": "^3.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
  }
}
